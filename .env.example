# Zabbix 7.0 LTS is a conservative default. You can change it to another
# official Zabbix Docker tag, for example: alpine-7.4-latest.
ZABBIX_IMAGE_TAG=alpine-7.0-latest

# Web login after first startup:
# URL: http://localhost:8080
# User: Admin
# Password: zabbix
ZABBIX_WEB_PORT=8080
ZABBIX_SERVER_PORT=10051

# Database settings used only inside Docker Compose.
MYSQL_ROOT_PASSWORD=change_me_root_2026
MYSQL_DATABASE=zabbix
MYSQL_USER=zabbix
MYSQL_PASSWORD=change_me_zabbix_2026

# Timezone and basic server cache settings.
PHP_TZ=Asia/Bangkok
ZBX_CACHESIZE=256M
ZBX_TRENDCACHESIZE=128M
ZBX_STARTJAVAPOLLERS=5
ZBX_STARTREPORTWRITERS=1
